{
	"name": "pharos-designer",
	"version": "1.2.0",
	"main": "main.js",
	"scripts": {
		"format": "prettier -w .",
		"lint:raw": "eslint",
		"lint": "yarn lint:raw .",
		"build": "yarn companion-module-build --dev",
		"package": "companion-module-build",
		"postinstall": "husky"
	},
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bitfocus/companion-module-pharos-designer.git"
	},
	"dependencies": {
		"@companion-module/base": "~1.12.1",
		"pharos-controllers": "^1.2.0",
		"ws": "^8.20.0"
	},
	"devDependencies": {
		"@companion-module/tools": "^2.6.1",
		"eslint": "^9.39.4",
		"husky": "^9.1.7",
		"lint-staged": "^15.5.2",
		"prettier": "^3.8.1",
		"typescript": "^5.0.4"
	},
	"lint-staged": {
		"*.{css,json,md,scss}": [
			"prettier --write"
		],
		"*.{js,jsx}": [
			"eslint --fix",
			"prettier --write"
		]
	},
	"prettier": "@companion-module/tools/.prettierrc.json",
	"engines": {
		"node": ">=18.12"
	},
	"packageManager": "yarn@1.22.22"
}
